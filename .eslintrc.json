{
  "extends": "next/core-web-vitals",
  "rules": {
    "@next/next/no-img-element": "off",
    "jsx-a11y/alt-text": "off",
    "react/display-name": "off",
    "react/jsx-max-props-per-line": [
      1,
      {
        "maximum": 1
      }
    ]
  },
  "parserOptions": {
    "requireConfigFile": false,
    "babelOptions": {
      "presets": [
        "next/babel"
      ]
    }
  },
  "settings": {
    "next": {
      "rootDir": "./"
    }
  }
}
